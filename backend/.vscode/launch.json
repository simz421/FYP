{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Flask (debug)",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "FLASK_APP": "app.py",
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1"
      },
      "args": ["run", "--host=0.0.0.0", "--port=5000"],
      "justMyCode": true
    }
  ]
}
